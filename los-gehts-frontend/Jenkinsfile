pipeline {
  agent any

  environment {
    CI = 'true'
    NEXT_TELEMETRY_DISABLED = '1'
    SMTP_SERVER = 'smtp.gmail.com'
    SMTP_PORT = '587'
  }

  stages {
    stage('Install Dependencies') {
      steps {
        dir('los-gehts-frontend') {
          sh 'npm ci'
        }
      }
    }

    stage('Test') {
      steps {
        dir('los-gehts-frontend') {
          sh 'npm test -- --runInBand --ci'
        }
      }
    }

    stage('Build') {
      steps {
        dir('los-gehts-frontend') {
          sh 'npm run build'
        }
      }
    }  

    stage('Email') {
      steps {
        dir('los-gehts-frontend') {
          sh 'python3 scripts/send_email.py'
          echo "E-mail enviado para ${EMAIL_TO}"
        }
      }
    }
  }

  post {
    success {
      archiveArtifacts(
          artifacts: 'los-gehts-frontend/.next/**',
          fingerprint: true
      )
    } 
  } 
}
