pipeline {
  agent any

  environment {
    CI = 'true'
    NEXT_TELEMETRY_DISABLED = '1'
  }

  stages {
    stage('Install Dependencies') {
      steps {
        dir('los-gehts-frontend') {
          sh 'npm ci'
        }
      }
    }

    stage('Test') {
      steps {
        dir('los-gehts-frontend') {
          sh 'npm test -- --runInBand --ci'
        }
      }
    }

    stage('Build') {
      steps {
        dir('los-gehts-frontend') {
          sh 'npm run build'
        }
      }
    }  
  }

  post {
    success {
      archiveArtifacts(
          artifacts: 'los-gehts-frontend/.next/**',
          fingerprint: true
      )
    } 
  } 
}
